<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>com.everpretty.paperclip-rag-weekly-report</string>

	<key>ProgramArguments</key>
	<array>
		<string>/Users/melodylu/PycharmProjects/paperclip/services/rag/scripts/weekly_report.sh</string>
	</array>

	<key>WorkingDirectory</key>
	<string>/Users/melodylu/PycharmProjects/paperclip/services/rag</string>

	<key>StartCalendarInterval</key>
	<dict>
		<key>Weekday</key>
		<integer>1</integer>
		<key>Hour</key>
		<integer>9</integer>
		<key>Minute</key>
		<integer>0</integer>
	</dict>

	<key>RunAtLoad</key>
	<false/>

	<key>StandardOutPath</key>
	<string>/Users/melodylu/.paperclip/logs/rag-weekly-report.out.log</string>
	<key>StandardErrorPath</key>
	<string>/Users/melodylu/.paperclip/logs/rag-weekly-report.err.log</string>

	<key>EnvironmentVariables</key>
	<dict>
		<key>HOME</key>
		<string>/Users/melodylu</string>
		<key>LANG</key>
		<string>en_US.UTF-8</string>
		<key>PATH</key>
		<string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
		<key>NO_PROXY</key>
		<string>*</string>
		<key>no_proxy</key>
		<string>*</string>
	</dict>
</dict>
</plist>
